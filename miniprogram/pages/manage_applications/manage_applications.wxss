/* pages/manage_applications/manage_applications.wxss */
.container {
  padding: 24rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header { margin-bottom: 24rpx; }
.title { display: block; font-size: 40rpx; font-weight: 600; color: #333; }

.tabs {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
}

.tab-active {
  color: #0079FE;
  font-weight: 600;
  border-bottom-color: #0079FE;
}

.loading-wrap, .empty-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 400rpx;
}

.app-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.app-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.app-job-info { flex: 1; }

.app-job-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.app-job-company {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-top: 4rpx;
}

.app-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  white-space: nowrap;
}

.status-pending { background: #fff3e0; color: #e67e22; }
.status-processing { background: #e3f2fd; color: #1976d2; }
.status-accepted { background: #e8f5e9; color: #2e7d32; }
.status-rejected { background: #fbe9e7; color: #c62828; }

.app-body {
  margin-bottom: 16rpx;
}

.app-time {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.app-remark {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
}

.app-actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.btn {
  font-size: 26rpx;
  padding: 10rpx 32rpx;
  border-radius: 8rpx;
  text-align: center;
}

.btn-process { background: #0079FE; color: #fff; }
.btn-accept { background: #07c160; color: #fff; }
.btn-reject { background: #e34d59; color: #fff; }
