/* pages/about/about.wxss */
.container { padding: 24rpx; background: #f5f5f5; min-height: 100vh; }

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  text-align: left;
}

.app-name { display: block; font-size: 48rpx; font-weight: 700; color: #0079FE; margin-bottom: 8rpx; }
.version { display: block; font-size: 26rpx; color: #999; margin-bottom: 24rpx; }
.desc { display: block; font-size: 28rpx; color: #666; line-height: 1.6; text-align: left; }

.feature-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.feature-dot { color: #0079FE; font-size: 28rpx; margin-right: 12rpx; }
.feature-text { font-size: 28rpx; color: #666; line-height: 1.5; }

.tech { display: block; font-size: 26rpx; color: #999; }

.footer { text-align: center; padding: 48rpx 0; }
.footer-text { font-size: 24rpx; color: #ccc; }
