/* pages/help/help.wxss */
.container { padding: 24rpx; background: #f5f5f5; min-height: 100vh; }

.header { margin-bottom: 32rpx; }
.title { display: block; font-size: 40rpx; font-weight: 600; color: #333; }
.subtitle { display: block; font-size: 26rpx; color: #999; margin-top: 8rpx; }

.faq-item {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.faq-q {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
}

.faq-q-text { font-size: 30rpx; font-weight: 500; color: #333; flex: 1; }
.faq-arrow { font-size: 36rpx; color: #0079FE; padding-left: 16rpx; }

.faq-a {
  padding: 0 32rpx 32rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.contact { text-align: center; padding: 48rpx 0; }
.contact-text { font-size: 24rpx; color: #ccc; }
