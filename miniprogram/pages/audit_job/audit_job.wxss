/* pages/audit_job/audit_job.wxss */
.container {
  padding: 24rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  margin-bottom: 32rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.loading-wrap, .empty-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 400rpx;
}

.job-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.job-info {
  margin-bottom: 24rpx;
}

.job-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.job-company {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.job-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.job-salary {
  font-size: 28rpx;
  color: #0079FE;
  font-weight: 500;
}

.job-location {
  font-size: 26rpx;
  color: #999;
}

.job-tags {
  display: flex;
  flex-wrap: wrap;
}

.job-actions {
  display: flex;
  gap: 24rpx;
  justify-content: flex-end;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 24rpx;
}

.btn-approve {
  background: #07c160;
  color: #fff;
  font-size: 28rpx;
  padding: 12rpx 40rpx;
  border-radius: 8rpx;
  text-align: center;
}

.btn-reject {
  background: #e34d59;
  color: #fff;
  font-size: 28rpx;
  padding: 12rpx 40rpx;
  border-radius: 8rpx;
  text-align: center;
}
